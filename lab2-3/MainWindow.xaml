<Window x:Class="lab2_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2_3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <ListView ItemsSource="{Binding People}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"  Margin="100,88,100,31">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="First Name" Width="145" DisplayMemberBinding="{Binding FirstName}" />
                    <GridViewColumn Header="Last Name" Width="145" DisplayMemberBinding="{Binding LastName}" />
                    <GridViewColumn Header="Year" Width="145" DisplayMemberBinding="{Binding YearOfBirth}" />
                    <GridViewColumn Header="City" Width="145" DisplayMemberBinding="{Binding City}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Button Content="Add" HorizontalAlignment="Left" Margin="100,25,0,0" VerticalAlignment="Top" Click="Button_Click" Height="35" Width="60"/>
    </Grid>
</Window>
