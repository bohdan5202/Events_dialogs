<Window x:Class="lab2_3.Modal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2_3"
        mc:Ignorable="d"
        Title="Modal dialog" Height="400" Width="412">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Label x:Name="main_label" Content="Add Single Person Information" 
               Grid.Row="0" 
               HorizontalAlignment="Center" 
               Margin="0,20,0,20" 
               FontSize="20" 
               FontWeight="Bold"/>

        <!-- First Name -->
        <Label Content="First Name:" 
               Grid.Row="1" 
               Margin="30,10,0,5" 
               HorizontalAlignment="Left"/>
        <TextBox x:Name="txtFirstNameModal" 
                 Grid.Row="1" 
                 Margin="150,10,30,5" 
                 Height="25"/>

        <!-- Last Name -->
        <Label Content="Last Name:" 
               Grid.Row="2" 
               Margin="30,10,0,5" 
               HorizontalAlignment="Left"/>
        <TextBox x:Name="txtLastNameModal" 
                 Grid.Row="2" 
                 Margin="150,10,30,5" 
                 Height="25"/>

        <!-- Year of Birth -->
        <Label Content="Year of Birth:" 
               Grid.Row="3" 
               Margin="30,10,0,5" 
               HorizontalAlignment="Left"/>
        <TextBox x:Name="txtYearOfBirthModal" 
                 Grid.Row="3" 
                 Margin="150,10,30,5" 
                 Height="25"/>

        <!-- City of Residence -->
        <Label Content="City of Residence:" 
               Grid.Row="4" 
               Margin="30,10,0,5" 
               HorizontalAlignment="Left"/>
        <TextBox x:Name="txtCityOfResidenceModal" 
                 Grid.Row="4" 
                 Margin="150,10,30,5" 
                 Height="25"/>

        <!-- Submit Button (optional) -->
        <Button x:Name="btnOK" 
                Content="OK" 
                Grid.Row="5" 
                Width="100" 
                Height="30" 
                Margin="70,25,0,210" 
                HorizontalAlignment="Left" Grid.RowSpan="2" Click="btnOK_Click"/>
        <Button x:Name="btnCancel" 
            Content="Cansel" 
            Grid.Row="5" 
            Width="100" 
            Height="30" 
            Margin="240,25,0,210" 
            HorizontalAlignment="Left" Grid.RowSpan="2" Click="btnCancel_Click"/>

    </Grid>
</Window>